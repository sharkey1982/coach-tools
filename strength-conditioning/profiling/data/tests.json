{
  "source": "YSCA",
  "sourceFull": "Youth Strength & Conditioning Assistant — Profiling Template",
  "scoringScale": {
    "summary": "1–5 functional scale",
    "levels": [
      { "score": 1, "label": "Major faults", "description": "Significant compensations or range deficit. Cannot complete movement to standard." },
      { "score": 2, "label": "Several compensations", "description": "Multiple faults present. Movement happens but quality is poor." },
      { "score": 3, "label": "Functional", "description": "Movement completed with minor compensations. Safe to load lightly." },
      { "score": 4, "label": "Good quality", "description": "Clean movement with very minor adjustments needed. Ready for progressive loading." },
      { "score": 5, "label": "Optimal", "description": "Full range, clean control, no compensations. Ready for high-intensity work." }
    ]
  },
